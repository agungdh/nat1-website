<div id="chatbot" class="chatbot">
    <div class="chat-header">
        <h2>AI Chatbot</h2>
    </div>
    <div id="chat-toasts" class="chat-toasts"></div>
    <div id="chat-messages" class="chat-messages">
        <div class="chat-empty">Ask me anything…</div>
    </div>
    <div class="chat-input-area">
        <textarea id="chat-input" placeholder="Type your message…" rows="1"></textarea>
        <button id="chat-send">Send</button>
    </div>
</div>

<script type="module">
    import { marked } from 'marked';

    marked.setOptions({ breaks: true });

    const messagesContainer = document.getElementById('chat-messages');
    const input = document.getElementById('chat-input') as HTMLTextAreaElement;
    const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;
    const toastsContainer = document.getElementById('chat-toasts');
    const emptyState = messagesContainer!.querySelector('.chat-empty');

    let messages: Array<{ role: string; content: string }> = [];
    let isStreaming = false;

    function showError(message: string) {
        const toast = document.createElement('div');
        toast.className = 'chat-toast chat-toast-error';
        toast.textContent = message;
        toastsContainer!.appendChild(toast);
        setTimeout(() => {
            toast.classList.add('chat-toast-hide');
            toast.addEventListener('transitionend', () => toast.remove());
        }, 4000);
    }

    function addMessage(role: string, content: string) {
        const div = document.createElement('div');
        div.className = `chat-message chat-${role}`;
        const bubble = document.createElement('div');
        bubble.className = 'chat-bubble';
        if (role === 'assistant' && content) {
            bubble.innerHTML = marked.parse(content) as string;
        } else {
            bubble.textContent = content;
        }
        div.appendChild(bubble);
        messagesContainer!.appendChild(div);
        if (emptyState) emptyState.remove();
        messagesContainer!.scrollTop = messagesContainer!.scrollHeight;
        return bubble;
    }

    async function sendMessage() {
        const content = input.value.trim();
        if (!content || isStreaming) return;

        input.value = '';
        input.style.height = 'auto';

        addMessage('user', content);
        messages.push({ role: 'user', content });

        const bubble = addMessage('assistant', '');
        let fullResponse = '';

        isStreaming = true;
        sendBtn.disabled = true;

        try {
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messages: [...messages] }),
            });

            if (!response.ok) throw new Error(`Server error: ${response.status}`);

            const reader = response.body!.getReader();
            const decoder = new TextDecoder();

            while (true) {
                const { done, value } = await reader.read();
                if (done) break;
                const chunk = decoder.decode(value, { stream: true });
                fullResponse += chunk;
                if (fullResponse.startsWith('__ERROR__')) break;
                bubble.innerHTML = marked.parse(fullResponse) as string;
                messagesContainer!.scrollTop = messagesContainer!.scrollHeight;
            }

            if (fullResponse.startsWith('__ERROR__')) {
                showError(fullResponse.slice(9));
                bubble.parentElement?.remove();
                messages.pop();
                return;
            }
        } catch (error) {
            const msg = error instanceof Error ? error.message : 'Unknown error';
            showError(msg);
            bubble.parentElement?.remove();
            messages.pop();
            return;
        } finally {
            if (!fullResponse.startsWith('__ERROR__')) {
                messages.push({ role: 'assistant', content: fullResponse });
            }
            isStreaming = false;
            sendBtn.disabled = false;
            input.focus();
        }
    }

    sendBtn.addEventListener('click', sendMessage);
    input.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    input.addEventListener('input', () => {
        input.style.height = 'auto';
        input.style.height = `${Math.min(input.scrollHeight, 120)}px`;
    });
</script>

