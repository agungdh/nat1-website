---
import os from 'node:os';
import { execSync } from 'node:child_process';
import Layout from '../layouts/Layout.astro';
import Chatbot from '../components/Chatbot.astro';

const renderTime = new Date().toLocaleString('id-ID', { timeZone: 'Asia/Jakarta' });
const cores = os.cpus().length;
const [load1, load5, load15] = os.loadavg();

const total = os.totalmem();
const free = os.freemem();
const used = total - free;
const ramPct = Number(((used / total) * 100).toFixed(1));

const diskRaw = execSync('df -h / | tail -1').toString().trim().split(/\s+/);
const [diskTotal, diskUsed, diskFree, diskPct] = [diskRaw[1], diskRaw[2], diskRaw[3], Number(diskRaw[4].replace('%', ''))];

const uptimeSec = os.uptime();
const d = Math.floor(uptimeSec / 86400);
const h = Math.floor((uptimeSec % 86400) / 3600);
const m = Math.floor((uptimeSec % 3600) / 60);

function fmt(bytes: number): string {
	const gb = bytes / 1024 ** 3;
	return gb >= 1 ? `${gb.toFixed(1)} GiB` : `${(bytes / 1024 ** 2).toFixed(0)} MiB`;
}
---

<Layout title="PoC: VPS NAT — No Public IP, Still Serving">
	<main class="page">
		<section class="hero">
			<div class="badge">Proof of Concept</div>
			<h1>VPS NAT + Cloudflare Tunnel</h1>
			<p class="subtitle">Serving HTTPS traffic to the world — from a server with <strong>no public IP address</strong>.</p>
		</section>

		<section class="explain">
			<h2>How does this work?</h2>
			<div class="steps">
				<div class="step">
					<div class="step-num">1</div>
					<div>
						<strong>VPS NAT</strong>
						<p>The server sits behind a NAT. It has no public IPv4, no inbound port open. Normally unreachable from the internet.</p>
					</div>
				</div>
				<div class="step">
					<div class="step-num">2</div>
					<div>
						<strong>Cloudflare Tunnel</strong>
						<p>A lightweight <code>cloudflared</code> daemon runs on the server, establishing an <em>outbound-only</em> persistent connection to Cloudflare's edge network.</p>
					</div>
				</div>
				<div class="step">
					<div class="step-num">3</div>
					<div>
						<strong>Reverse Proxy</strong>
						<p>Cloudflare terminates TLS at its edge and forwards requests over the tunnel to the server. No open ports, no port forwarding, no DDNS needed.</p>
					</div>
				</div>
				<div class="step">
					<div class="step-num">4</div>
					<div>
						<strong>Astro SSR</strong>
						<p>This website is built with <a href="https://astro.build">Astro</a> in <em>server-side rendering</em> mode. Every page is rendered on-demand on the Node.js server at request time.</p>
					</div>
				</div>
				<div class="step">
					<div class="step-num">5</div>
					<div>
						<strong>CI/CD Pipeline</strong>
						<p>GitHub Actions builds a Docker image on every push to <code>master</code> and publishes it to both Docker Hub and GitHub Container Registry. Pull and run anywhere.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="stats">
			<h2>Server Statistics <span class="ssr-badge">SSR — Live Data</span></h2>
			<p class="stats-note">These numbers are computed fresh on every request. Refresh the page — the timestamp and loads will change. That proves this is <strong>not</strong> a static site.</p>
			<div class="cards">
				<div class="card">
					<div class="card-icon">&#9200;</div>
					<div class="card-label">Timestamp</div>
					<div class="card-value">{renderTime} WIB</div>
					<div class="card-sub">Uptime: {d}d {h}h {m}m</div>
				</div>
				<div class="card">
					<div class="card-icon">&#9881;</div>
					<div class="card-label">CPU ({cores} cores)</div>
					<div class="card-value">{load1.toFixed(2)} / {load5.toFixed(2)} / {load15.toFixed(2)}</div>
					<div class="card-sub">1m / 5m / 15m load avg</div>
				</div>
				<div class="card">
					<div class="card-icon">&#9776;</div>
					<div class="card-label">Memory</div>
					<div class="card-value">{ramPct}% used</div>
					<div class="card-sub">{fmt(used)} / {fmt(total)}</div>
					<div class="bar"><div class="bar-fill" style={`width:${ramPct}%`}></div></div>
				</div>
				<div class="card">
					<div class="card-icon">&#128190;</div>
					<div class="card-label">Disk</div>
					<div class="card-value">{diskPct}% used</div>
					<div class="card-sub">{diskUsed} / {diskTotal} ({diskFree} free)</div>
					<div class="bar"><div class="bar-fill" style={`width:${diskPct}%`}></div></div>
				</div>
			</div>
		</section>

		<Chatbot />

		<footer>
			<p>This page is rendered at request time by Astro SSR running on Node.js inside a Docker container.</p>
			<p>No public IP. No inbound ports. Just Cloudflare Tunnel.</p>
			<div class="links">
				<a href="https://github.com/agungdh/nat1-website">GitHub</a>
				<a href="https://hub.docker.com/r/agungdh/nat1-website">Docker Hub</a>
				<a href="https://github.com/agungdh/nat1-website/pkgs/container/nat1-website">GHCR</a>
			</div>
		</footer>
	</main>
</Layout>

<style>
	*, *::before, *::after { box-sizing: border-box; }

	body {
		margin: 0;
		font-family: 'Inter', system-ui, -apple-system, sans-serif;
		background: #0a0a0f;
		color: #e4e4e7;
		line-height: 1.6;
	}

	.page {
		max-width: 800px;
		margin: 0 auto;
		padding: 48px 24px 80px;
	}

	.hero {
		text-align: center;
		padding: 60px 0 40px;
	}

	.badge {
		display: inline-block;
		background: linear-gradient(135deg, #f97316, #ef4444);
		color: #fff;
		font-size: 12px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 4px 12px;
		border-radius: 20px;
		margin-bottom: 16px;
	}

	.hero h1 {
		font-size: 36px;
		font-weight: 800;
		margin: 0 0 8px;
		background: linear-gradient(135deg, #f97316, #facc15, #ef4444);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.subtitle {
		font-size: 16px;
		color: #a1a1aa;
		max-width: 500px;
		margin: 0 auto;
	}

	.subtitle strong {
		color: #f97316;
	}

	.explain { margin: 60px 0; }

	.explain h2 {
		font-size: 22px;
		font-weight: 700;
		margin: 0 0 24px;
		text-align: center;
	}

	.steps { display: flex; flex-direction: column; gap: 16px; }

	.step {
		display: flex;
		gap: 16px;
		background: #18181b;
		border: 1px solid #27272a;
		border-radius: 12px;
		padding: 16px 20px;
	}

	.step-num {
		flex-shrink: 0;
		width: 32px;
		height: 32px;
		background: linear-gradient(135deg, #f97316, #ef4444);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 700;
		font-size: 14px;
		color: #fff;
	}

	.step strong { font-size: 15px; color: #fafafa; }
	.step p { margin: 4px 0 0; font-size: 13px; color: #a1a1aa; }
	.step code {
		background: #27272a;
		padding: 1px 6px;
		border-radius: 4px;
		font-size: 12px;
		color: #f97316;
	}
	.step a { color: #f97316; }

	.stats { margin: 60px 0; }

	.stats h2 {
		font-size: 22px;
		font-weight: 700;
		margin: 0 0 4px;
		text-align: center;
	}

	.ssr-badge {
		display: inline-block;
		background: #22c55e1a;
		color: #22c55e;
		font-size: 12px;
		font-weight: 600;
		padding: 2px 10px;
		border-radius: 10px;
		border: 1px solid #22c55e33;
		vertical-align: middle;
		margin-left: 8px;
	}

	.stats-note {
		text-align: center;
		font-size: 13px;
		color: #71717a;
		margin: 8px 0 24px;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
		gap: 12px;
	}

	.card {
		background: #18181b;
		border: 1px solid #27272a;
		border-radius: 12px;
		padding: 16px;
		text-align: center;
	}

	.card-icon { font-size: 24px; margin-bottom: 4px; }

	.card-label {
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #71717a;
		margin-bottom: 4px;
	}

	.card-value {
		font-size: 18px;
		font-weight: 700;
		color: #fafafa;
	}

	.card-sub {
		font-size: 11px;
		color: #71717a;
		margin-top: 2px;
	}

	.bar {
		margin-top: 8px;
		width: 100%;
		height: 4px;
		background: #27272a;
		border-radius: 2px;
		overflow: hidden;
	}

	.bar-fill {
		height: 100%;
		background: linear-gradient(90deg, #f97316, #ef4444);
		border-radius: 2px;
	}

	footer {
		text-align: center;
		margin-top: 40px;
		padding-top: 24px;
		border-top: 1px solid #27272a;
	}

	footer p {
		font-size: 12px;
		color: #52525b;
		margin: 2px 0;
	}

	.links {
		margin-top: 12px;
		display: flex;
		justify-content: center;
		gap: 16px;
	}

	.links a {
		color: #f97316;
		font-size: 13px;
		font-weight: 600;
		text-decoration: none;
		transition: color 0.2s;
	}

	.links a:hover { color: #fb923c; }

	@media (max-width: 600px) {
		.page { padding: 24px 16px 60px; }
		.hero { padding: 40px 0 24px; }
		.hero h1 { font-size: 26px; }
		.cards { grid-template-columns: 1fr 1fr; }
	}
</style>
